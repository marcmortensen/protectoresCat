{
  "name": "protectores-cat",
  "version": "1.0.0",
  "description": "Recopilation of active animal shelter in Catalonia",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "test-unit-watch:all": "turbo run test:unit-watch",
    "test-unit-watch:shelters": "turbo run test:unit-watch --filter=@protectorescat/shelters",
    "test-unit-run:all": "turbo run test:unit-run",
    "test-unit-run:shelters": "turbo run test:unit-run --filter=@protectorescat/shelters",
    "tsc:shelters": "turbo run tsc --filter=@protectorescat/shelters",
    "tsc:web": "turbo run tsc --filter=@protectorescat/web",
    "tsc:all": "turbo run tsc",
    "build:web": "turbo run build --filter @protectorescat/web"
  },
  "private": true,
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@tsconfig/node22": "22.0.5",
    "@types/node": "22.18.12",
    "@typescript-eslint/eslint-plugin": "8.58.0",
    "@typescript-eslint/parser": "8.58.0",
    "@typescript-eslint/utils": "8.58.0",
    "@vitest/eslint-plugin": "1.6.14",
    "@vue/eslint-config-prettier": "10.2.0",
    "@vue/eslint-config-typescript": "14.7.0",
    "@vue/tsconfig": "0.9.1",
    "eslint": "10.1.0",
    "globals": "17.4.0",
    "only-allow": "1.2.2",
    "prettier": "3.8.1",
    "turbo": "2.9.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.0"
  },
  "packageManager": "pnpm@10.19.0",
  "engines": {
    "node": "22.x"
  },
  "pnpm": {
    "overrides": {
      "sharp": "0.33.4"
    }
  }
}
